#Область ПрограммныйИнтерфейс

// Формирует структуру сведений о внешней обработке для подключения к информационной базе:
// вид «ДополнительнаяОбработка», наименование, версия, команда открытия с вызовом серверного метода.
//
// Возвращаемое значение:
//  Структура - поля «Вид», «Наименование», «Версия», «БезопасныйРежим», «Информация», «Команды»
//  (таблица команд из ПолучитьТаблицуКоманд с одной зарегистрированной командой).
//
Функция СведенияОВнешнейОбработке() Экспорт
    
    ИмяОбработки = ЭтотОбъект.Метаданные().Имя; 
    Синоним = ЭтотОбъект.Метаданные().Синоним; 
    Синоним = ?(ЗначениеЗаполнено(Синоним),Синоним, ИмяОбработки);
	
    РегистрационныеДанные = Новый Структура;
    РегистрационныеДанные.Вставить("Вид","ДополнительнаяОбработка");
    РегистрационныеДанные.Вставить("Наименование", Синоним);
    РегистрационныеДанные.Вставить("Версия", "1.0");
    РегистрационныеДанные.Вставить("БезопасныйРежим", Ложь);
    РегистрационныеДанные.Вставить("Информация", "Обработка """ + Синоним + """");
    
    ТаблицаКоманд = ПолучитьТаблицуКоманд();
    ДобавитьКоманду(ТаблицаКоманд, Синоним, ИмяОбработки , "ВызовСерверногоМетода", Истина, );
        
    РегистрационныеДанные.Вставить("Команды", ТаблицаКоманд);
    
    Возврат РегистрационныеДанные;
                                       
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создаёт пустую таблицу значений с колонками, ожидаемыми платформой для описания команд внешней обработки.
//
// Возвращаемое значение:
//  ТаблицаЗначений - колонки: Представление, Идентификатор, Использование, ПоказыватьОповещение, Модификатор.
//
Функция ПолучитьТаблицуКоманд()
    
    Команды = Новый ТаблицаЗначений;
    Команды.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка")); 
    Команды.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
    Команды.Колонки.Добавить("Использование", Новый ОписаниеТипов("Строка"));
    Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
    Команды.Колонки.Добавить("Модификатор", Новый ОписаниеТипов("Строка"));
	
    Возврат Команды;
   
КонецФункции

// Добавляет в переданную таблицу команд одну строку с переданными реквизитами команды.
//
// Параметры:
//  ТаблицаКоманд - ТаблицаЗначений - таблица в формате ПолучитьТаблицуКоманд;
//  Представление - Строка - текст команды в интерфейсе;
//  Идентификатор - Строка - имя команды, передаётся при выполнении;
//  Использование - Строка - способ вызова (по умолчанию «ОткрытиеФормы»);
//  ПоказыватьОповещение - Булево - показывать ли оповещение при запуске;
//  Модификатор - Строка - дополнительный модификатор команды (по умолчанию «ПечатьMXL»).
//
Процедура ДобавитьКоманду(ТаблицаКоманд, 
						  Представление, 
						  Идентификатор, 
						  Использование = "ОткрытиеФормы", 
						  ПоказыватьОповещение = Ложь, 
						  Модификатор = "ПечатьMXL")
    
    НоваяКоманда = ТаблицаКоманд.Добавить();
    НоваяКоманда.Представление = Представление;
    НоваяКоманда.Идентификатор = Идентификатор;
    НоваяКоманда.Использование = Использование;
    НоваяКоманда.ПоказыватьОповещение = ПоказыватьОповещение;
    НоваяКоманда.Модификатор = Модификатор;

КонецПроцедуры 

#КонецОбласти

// Обрабатывает выполнение команды внешней обработки из подсистемы дополнительных отчётов и обработок:
// записывает в журнал регистрации информационное событие с именем события «Тест» и текстом идентификатора команды.
//
// Параметры:
//  ИдентификаторКоманды - Произвольный - идентификатор команды, переданный платформой при вызове.
//
Процедура ВыполнитьКоманду(ИдентификаторКоманды) Экспорт 
	ЗаписьЖурналаРегистрации("Тест", УровеньЖурналаРегистрации.Информация,,, "" + ИдентификаторКоманды);  
КонецПроцедуры 