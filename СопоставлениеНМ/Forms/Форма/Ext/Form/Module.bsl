#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Элементы.Найти("ЗагрузитьИзЭксельКнопка") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КомандаЗагрузить = Команды.Добавить("ЗагрузитьИзЭксель");
	КомандаЗагрузить.Заголовок = "Загрузить из Excel";
	КомандаЗагрузить.Действие = "ЗагрузитьИзЭксель";
	
	КнопкаЗагрузить = Элементы.Добавить("ЗагрузитьИзЭксельКнопка", Тип("КнопкаФормы"), Элементы.ФормаКоманднаяПанель);
	КнопкаЗагрузить.ИмяКоманды = "ЗагрузитьИзЭксель";
	КнопкаЗагрузить.Заголовок = "Загрузить из Excel";
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьИзЭксель(Команда)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл Excel";
	Диалог.Фильтр = "Книга Excel (*.xlsx)|*.xlsx|Excel 97-2003 (*.xls)|*.xls|Все файлы (*.*)|*.*";
	Диалог.МножественныйВыбор = Ложь;
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзЭксельПослеВыбораФайла", ЭтотОбъект);
	Диалог.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзЭксельПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Путь = "";
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТипРезультата = ТипЗнч(ВыбранныеФайлы);
	Если ТипРезультата = Тип("Строка") Тогда
		Путь = ВыбранныеФайлы;
	ИначеЕсли ТипРезультата = Тип("Массив") Или ТипРезультата = Тип("ФиксированныйМассив") Тогда
		Если ВыбранныеФайлы.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		Путь = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Путь) Тогда
		Возврат;
	КонецЕсли;
	
	// Расширение из имени файла — без объекта Файл и без обращений к ФС на клиенте
	// (Существует и др. синхронные методы могут быть запрещены режимом интерфейса).
	ИмяФайла = Путь;
	Поз = СтрНайти(ИмяФайла, "\");
	Пока Поз > 0 Цикл
		ИмяФайла = Сред(ИмяФайла, Поз + 1);
		Поз = СтрНайти(ИмяФайла, "\");
	КонецЦикла;
	Поз = СтрНайти(ИмяФайла, "/");
	Пока Поз > 0 Цикл
		ИмяФайла = Сред(ИмяФайла, Поз + 1);
		Поз = СтрНайти(ИмяФайла, "/");
	КонецЦикла;
	ЧастиИмени = СтрРазделить(ИмяФайла, ".");
	Расширение = "";
	Если ЧастиИмени.Количество() > 1 Тогда
		Расширение = НРег(ЧастиИмени[ЧастиИмени.Количество() - 1]);
	КонецЕсли;
	Если Расширение <> "xlsx" И Расширение <> "xls" Тогда
		Расширение = "xlsx";
	КонецЕсли;
	
	Попытка
		Двоичные = Новый ДвоичныеДанные(Путь);
	Исключение
		Сообщить(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), СтатусСообщения.Важное);
		Возврат;
	КонецПопытки;
	
	Попытка
		ЧислоЗагружено = ЗагрузитьИзЭксельНаСервере(Двоичные, Расширение);
		Сообщить(СтрШаблон("Загружено строк: %1.", Формат(ЧислоЗагружено, "ЧГ=0")));
	Исключение
		Сообщить(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), СтатусСообщения.Важное);
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура СопоставитьНМ(Команда)
	
	НачалоМс = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Сообщить("Сопоставление НМ: начало…");
	
	СопоставитьНМНаСервере();
	
	ДлительностьМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоМс;
	ДлительностьСек = ДлительностьМс / 1000;
	Сообщить(СтрШаблон("Сопоставление НМ: готово за %1 с.", Формат(ДлительностьСек, "ЧЦ=10; ЧДЦ=2")));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СопоставитьНМНаСервере()
	
	ПорогСходства = 0.7;
	ЧислоРезультатовПоиска = 20;
	
	Дерево.ПолучитьЭлементы().Очистить();
	
	Настройки = НастройкиВыгрузкиНМ();
	
	СтрокиСметы = Новый Массив;
	Для Каждого СтрокаТЧ Из Объект.СметныеПозиции Цикл
		Текст = СокрЛП(СтрокаТЧ.Наименование);
		Если ЗначениеЗаполнено(Текст) Тогда
			СтрокиСметы.Добавить(Текст);
		КонецЕсли;
	КонецЦикла;
	
	ВсегоСтрок = СтрокиСметы.Количество();
	Если ВсегоСтрок = 0 Тогда
		Сообщить("Сопоставление НМ: нет заполненных наименований в табличной части «Сметные позиции».");
		Возврат;
	КонецЕсли;
	
	Сообщить(СтрШаблон("Сопоставление НМ: строк к обработке: %1.", Формат(ВсегоСтрок, "ЧГ=0")));
	Сообщить("Сопоставление НМ: подключение к коллекции Chroma…");
	
	ИдКоллекции = ChromaПолучитьИдКоллекции(Настройки);
	
	РазмерБатча = Настройки.РазмерБатча;
	Обработано = 0;
	БезКандидатов = 0;
	
	Пока Обработано < ВсегоСтрок Цикл
		
		КонецБатча = Обработано + РазмерБатча - 1;
		Если КонецБатча > ВсегоСтрок - 1 Тогда
			КонецБатча = ВсегоСтрок - 1;
		КонецЕсли;
		
		МассивТекстовЗапроса = Новый Массив;
		Для Индекс = Обработано По КонецБатча Цикл
			МассивТекстовЗапроса.Добавить("query: " + СтрокиСметы[Индекс]);
		КонецЦикла;
		
		Сообщить(СтрШаблон("Сопоставление НМ: батч строк %1…%2: эмбеддинги LM Studio…",
			Формат(Обработано + 1, "ЧГ=0"),
			Формат(КонецБатча + 1, "ЧГ=0")));
		
		МассивЭмбеддингов = LMStudioПолучитьЭмбеддинги(Настройки, МассивТекстовЗапроса);
		
		РезультатЗапроса = ChromaВыполнитьЗапрос(Настройки, ИдКоллекции, МассивЭмбеддингов, ЧислоРезультатовПоиска);
		
		Для ИндексВБатче = 0 По МассивТекстовЗапроса.Количество() - 1 Цикл
			
			ИндексСтроки = Обработано + ИндексВБатче;
			ТекстСметы = СтрокиСметы[ИндексСтроки];
			
			СтрокаРодитель = Дерево.ПолучитьЭлементы().Добавить();
			СтрокаРодитель.Наименование = ТекстСметы;
			СтрокаРодитель.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
			
			Кандидаты = РезультатЗапроса.КандидатыПоЗапросу.Получить(ИндексВБатче);
			ДобавленХотяБыОдин = Ложь;
			
			Для Каждого К Из Кандидаты Цикл
				
				Если К.Сходство < ПорогСходства Тогда
					Продолжить;
				КонецЕсли;
				
				СсылкаНМ = НоменклатураПоGuidИзМетаданных(К.МетаданныеЗаписи);
				Если СсылкаНМ = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				ИмяДляОтображения = Строка(К.ИмяНоменклатуры);
				Если Не ЗначениеЗаполнено(ИмяДляОтображения) Тогда
					ИмяДляОтображения = Строка(СсылкаНМ);
				КонецЕсли;
				
				Процент = Окр(К.Сходство * 100, 0);
				
				Дочерняя = СтрокаРодитель.ПолучитьЭлементы().Добавить();
				Дочерняя.Наименование = СтрШаблон("%1 (%2%%)", ИмяДляОтображения, Формат(Процент, "ЧГ=0"));
				Дочерняя.Номенклатура = СсылкаНМ;
				ДобавленХотяБыОдин = Истина;
				
			КонецЦикла;
			
			Если Не ДобавленХотяБыОдин Тогда
				БезКандидатов = БезКандидатов + 1;
			КонецЕсли;
			
		КонецЦикла;
		
		Обработано = КонецБатча + 1;
		
	КонецЦикла;
	
	Сообщить(СтрШаблон("Сопоставление НМ: обработано строк: %1, без кандидатов ≥ 70%%: %2.",
		Формат(ВсегоСтрок, "ЧГ=0"),
		Формат(БезКандидатов, "ЧГ=0")));
	
КонецПроцедуры

// Преобразует distance из Chroma (косинусная метрика: расстояние = 1 − cos_sim для нормированных векторов) в сходство [0; 1].
&НаСервере
Функция ChromaРасстояниеВСходство(Расстояние)
	
	Возврат 1 - Расстояние;
	
КонецФункции

&НаСервере
Функция НоменклатураПоGuidИзМетаданных(МетаданныеЗаписи)
	
	Если МетаданныеЗаписи = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	GuidСтрока = JSONЗначениеПоКлючу(МетаданныеЗаписи, "guid");
	Если Не ЗначениеЗаполнено(GuidСтрока) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Уид = Новый УникальныйИдентификатор(Строка(GuidСтрока));
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Ссылка = Справочники.Номенклатура.ПолучитьСсылку(Уид);
	Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

&НаСервере
Функция НастройкиВыгрузкиНМ()
	
	Н = Новый Структура;
	Н.Вставить("LMСервер", "192.168.0.19");
	Н.Вставить("LMПорт", 1234);
	Н.Вставить("LMМодель", "text-embedding-multilingual-e5-large.gguf");
	Н.Вставить("LMТокен", "lm-studio");
	Н.Вставить("ChromaСервер", "192.168.0.19");
	Н.Вставить("ChromaПорт", 8020);
	Н.Вставить("ChromaИмяКоллекции", "nomenclature");
	Н.Вставить("ChromaTenant", "default_tenant");
	Н.Вставить("ChromaDatabase", "default_database");
	Н.Вставить("РазмерБатча", 32);
	Н.Вставить("ТаймаутСек", 300);
	Возврат Н;
	
КонецФункции

&НаСервере
Функция ChromaПолучитьИдКоллекции(Настройки)
	
	Путь = СтрШаблон("/api/v2/tenants/%1/databases/%2/collections",
		Настройки.ChromaTenant,
		Настройки.ChromaDatabase);
	
	ТелоСтруктура = Новый Структура;
	ТелоСтруктура.Вставить("name", Настройки.ChromaИмяКоллекции);
	ТелоСтруктура.Вставить("get_or_create", Истина);
	
	Тело = ЗначениеВСтрокуJSON(ТелоСтруктура);
	
	Ответ = HTTPОтправитьPOST(
		Настройки.ChromaСервер,
		Настройки.ChromaПорт,
		Ложь,
		Путь,
		Тело,
		Настройки.ТаймаутСек,
		"");
	
	ПроверитьОтветHTTP(Ответ, "Chroma create collection");
	
	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	Данные = ПрочитатьJSONИзСтроки(ТекстОтвета);
	ИдКоллекции = JSONЗначениеПоКлючу(Данные, "id");
	Если ИдКоллекции = Неопределено Тогда
		ВызватьИсключение "Chroma: в ответе нет поля id.";
	КонецЕсли;
	
	Возврат Строка(ИдКоллекции);
	
КонецФункции

// Возвращает структуру: КандидатыПоЗапросу — массив (по индексу запроса) массивов структур с полями Сходство, МетаданныеЗаписи, ИмяНоменклатуры; кандидаты отсортированы по убыванию сходства.
&НаСервере
Функция ChromaВыполнитьЗапрос(Настройки, ИдКоллекции, МассивЭмбеддингов, NРезультатов)
	
	Путь = СтрШаблон("/api/v2/tenants/%1/databases/%2/collections/%3/query",
		Настройки.ChromaTenant,
		Настройки.ChromaDatabase,
		ИдКоллекции);
	
	// В Chroma v2 для query поле include допускает только: distances, documents, embeddings, metadatas, uris (не "ids" — иначе HTTP 422).
	МассивВключить = Новый Массив;
	МассивВключить.Добавить("distances");
	МассивВключить.Добавить("metadatas");
	
	ТелоСтруктура = Новый Структура;
	ТелоСтруктура.Вставить("query_embeddings", МассивЭмбеддингов);
	ТелоСтруктура.Вставить("n_results", NРезультатов);
	ТелоСтруктура.Вставить("include", МассивВключить);
	
	Тело = ЗначениеВСтрокуJSON(ТелоСтруктура);
	
	Ответ = HTTPОтправитьPOST(
		Настройки.ChromaСервер,
		Настройки.ChromaПорт,
		Ложь,
		Путь,
		Тело,
		Настройки.ТаймаутСек,
		"");
	
	ПроверитьОтветHTTP(Ответ, "Chroma query");
	
	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	Корень = ПрочитатьJSONИзСтроки(ТекстОтвета);
	
	МассивИдВнешний = JSONЗначениеПоКлючу(Корень, "ids");
	МассивДистанцийВнешний = JSONЗначениеПоКлючу(Корень, "distances");
	МассивМетаданныхВнешний = JSONЗначениеПоКлючу(Корень, "metadatas");
	
	Результат = Новый Структура;
	КандидатыПоЗапросу = Новый Массив;
	
	ЧислоЗапросов = МассивЭмбеддингов.Количество();
	
	Для ИндексЗапроса = 0 По ЧислоЗапросов - 1 Цикл
		
		ИдДляЗапроса = ЭлементМассиваПоИндексу(МассивИдВнешний, ИндексЗапроса);
		ДистанцииДляЗапроса = ЭлементМассиваПоИндексу(МассивДистанцийВнешний, ИндексЗапроса);
		МетаданныеДляЗапроса = ЭлементМассиваПоИндексу(МассивМетаданныхВнешний, ИндексЗапроса);
		
		СписокКандидатов = Новый Массив;
		
		Если ИдДляЗапроса = Неопределено Или ДистанцииДляЗапроса = Неопределено Тогда
			КандидатыПоЗапросу.Добавить(СписокКандидатов);
			Продолжить;
		КонецЕсли;
		
		КоличествоК = ИдДляЗапроса.Количество();
		Для ИндексК = 0 По КоличествоК - 1 Цикл
			
			ИдСтрока = ЭлементМассиваПоИндексу(ИдДляЗапроса, ИндексК);
			Расстояние = ЭлементМассиваПоИндексу(ДистанцииДляЗапроса, ИндексК);
			Мета = Неопределено;
			Если МетаданныеДляЗапроса <> Неопределено И ИндексК < МетаданныеДляЗапроса.Количество() Тогда
				Мета = ЭлементМассиваПоИндексу(МетаданныеДляЗапроса, ИндексК);
			КонецЕсли;
			
			Если Расстояние = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Сходство = ChromaРасстояниеВСходство(Число(Расстояние));
			
			ИмяНм = "";
			Если Мета <> Неопределено Тогда
				ИмяНм = Строка(JSONЗначениеПоКлючу(Мета, "nm_name"));
			КонецЕсли;
			
			Кандидат = Новый Структура;
			Кандидат.Вставить("Сходство", Сходство);
			Кандидат.Вставить("МетаданныеЗаписи", Мета);
			Кандидат.Вставить("ИмяНоменклатуры", ИмяНм);
			Кандидат.Вставить("ИдЗаписи", ИдСтрока);
			
			СписокКандидатов.Добавить(Кандидат);
			
		КонецЦикла;
		
		СортироватьКандидатовПоСходству(СписокКандидатов);
		КандидатыПоЗапросу.Добавить(СписокКандидатов);
		
	КонецЦикла;
	
	Результат.Вставить("КандидатыПоЗапросу", КандидатыПоЗапросу);
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ЭлементМассиваПоИндексу(МассивИлиСписок, Индекс)
	
	Если МассивИлиСписок = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Индекс < 0 Или Индекс >= МассивИлиСписок.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат МассивИлиСписок[Индекс];
	
КонецФункции

&НаСервере
Процедура СортироватьКандидатовПоСходству(СписокКандидатов)
	
	// Пузырьковая сортировка по убыванию Сходство (малые N).
	Всего = СписокКандидатов.Количество();
	Если Всего < 2 Тогда
		Возврат;
	КонецЕсли;
	
	Для Индекс = 0 По Всего - 2 Цикл
		Для Индекс2 = Индекс + 1 По Всего - 1 Цикл
			Если СписокКандидатов[Индекс].Сходство < СписокКандидатов[Индекс2].Сходство Тогда
				Врем = СписокКандидатов[Индекс];
				СписокКандидатов[Индекс] = СписокКандидатов[Индекс2];
				СписокКандидатов[Индекс2] = Врем;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция LMStudioПолучитьЭмбеддинги(Настройки, МассивТекстов)
	
	Путь = "/v1/embeddings";
	ТелоСтруктура = Новый Структура;
	ТелоСтруктура.Вставить("model", Настройки.LMМодель);
	ТелоСтруктура.Вставить("input", МассивТекстов);
	
	Тело = ЗначениеВСтрокуJSON(ТелоСтруктура);
	
	Ответ = HTTPОтправитьPOST(
		Настройки.LMСервер,
		Настройки.LMПорт,
		Ложь,
		Путь,
		Тело,
		Настройки.ТаймаутСек,
		Настройки.LMТокен);
	
	ПроверитьОтветHTTP(Ответ, "LM Studio embeddings");
	
	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	Корень = ПрочитатьJSONИзСтроки(ТекстОтвета);
	МассивДанных = JSONЗначениеПоКлючу(Корень, "data");
	Если МассивДанных = Неопределено Тогда
		ВызватьИсключение "LM Studio: в ответе нет поля data.";
	КонецЕсли;
	
	Результат = Новый Массив;
	СоответствиеИндексВектор = Новый Соответствие;
	
	Для Каждого Элемент Из МассивДанных Цикл
		ИндексЭлемента = JSONЗначениеПоКлючу(Элемент, "index");
		Вектор = JSONЗначениеПоКлючу(Элемент, "embedding");
		СоответствиеИндексВектор.Вставить(ИндексЭлемента, Вектор);
	КонецЦикла;
	
	Для Индекс = 0 По МассивТекстов.Количество() - 1 Цикл
		ВекторПоИндексу = СоответствиеИндексВектор.Получить(Индекс);
		Если ВекторПоИндексу = Неопределено Тогда
			ВызватьИсключение СтрШаблон("LM Studio: нет embedding для index=%1.", Формат(Индекс, "ЧГ=0"));
		КонецЕсли;
		Результат.Добавить(ВекторПоИндексу);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция HTTPОтправитьPOST(Сервер, Порт, ЗащищенноеСоединение, Путь, Тело, ТаймаутСек, ТокенBearer)
	
	Соединение = Новый HTTPСоединение(Сервер, Порт, , , , ТаймаутСек, ЗащищенноеСоединение);
	Запрос = Новый HTTPЗапрос(Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Если ЗначениеЗаполнено(ТокенBearer) Тогда
		Запрос.Заголовки.Вставить("Authorization", СтрШаблон("Bearer %1", ТокенBearer));
	КонецЕсли;
	Запрос.УстановитьТелоИзСтроки(Тело, КодировкаТекста.UTF8);
	Возврат Соединение.ОтправитьДляОбработки(Запрос);
	
КонецФункции

&НаСервере
Функция JSONЗначениеПоКлючу(ОбъектJSON, ИмяКлюча)
	
	Если ОбъектJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипОбъекта = ТипЗнч(ОбъектJSON);
	Если ТипОбъекта = Тип("Соответствие") Или ТипОбъекта = Тип("ФиксированноеСоответствие") Тогда
		Возврат ОбъектJSON.Получить(ИмяКлюча);
	КонецЕсли;
	
	Значение = Неопределено;
	Если ТипОбъекта = Тип("Структура") Или ТипОбъекта = Тип("ФиксированнаяСтруктура") Тогда
		Если ОбъектJSON.Свойство(ИмяКлюча, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Процедура ПроверитьОтветHTTP(Ответ, Контекст)
	
	Код = Ответ.КодСостояния;
	Если Код < 200 Или Код >= 300 Тогда
		ТекстОшибки = "";
		Попытка
			ТекстОшибки = Ответ.ПолучитьТелоКакСтроку();
		Исключение
			ТекстОшибки = "";
		КонецПопытки;
		Сообщить(СтрШаблон("%1: HTTP %2. %3", Контекст, Формат(Код, "ЧГ=0"), ТекстОшибки));
		ВызватьИсключение СтрШаблон("%1: HTTP %2", Контекст, Формат(Код, "ЧГ=0"));
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗначениеВСтрокуJSON(Значение)
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Значение);
	Возврат Запись.Закрыть();
	
КонецФункции

&НаСервере
Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(Чтение, Истина);
	
КонецФункции

&НаСервере
Функция ЗагрузитьИзЭксельНаСервере(ДанныеФайла, Расширение)
	
	ИмяВременного = ПолучитьИмяВременногоФайла(Расширение);
	ДанныеФайла.Записать(ИмяВременного);
	
	ЧислоСтрок = 0;
	
	Попытка
		
		ТабДок = Новый ТабличныйДокумент;
		// Один аргумент: формат по расширению имени файла (избегает несоответствия типа
		// второго параметра у Прочитать в части сборок платформы / перегрузок метода).
		ТабДок.Прочитать(ИмяВременного);
		
		ИндексКолонки = ИндексКолонкиПоЗаголовку(ТабДок, "Наименование тмц");
		Если ИндексКолонки = 0 Тогда
			ВызватьИсключение "В первой строке файла не найдена колонка «Наименование тмц».";
		КонецЕсли;
		
		Объект.СметныеПозиции.Очистить();
		
		Высота = Число(ТабДок.ВысотаТаблицы);
		Для НомерСтроки = 2 По Высота Цикл
			
			ОбластьЯчейки = ТабДок.Область(НомерСтроки, ИндексКолонки, НомерСтроки, ИндексКолонки);
			ТекстЗнач = СокрЛП(ОбластьЯчейки.Текст);
			ТекстЗнач = СтрЗаменить(ТекстЗнач, Символ(160), " ");
			ТекстЗнач = СокрЛП(ТекстЗнач);
			Если Не ЗначениеЗаполнено(ТекстЗнач) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТЧ = Объект.СметныеПозиции.Добавить();
			СтрокаТЧ.Наименование = Лев(ТекстЗнач, 150);
			ЧислоСтрок = ЧислоСтрок + 1;
			
		КонецЦикла;
		
		Модифицированность = Истина;
		
	Исключение
		Инфо = ИнформацияОбОшибке();
		Попытка
			УдалитьФайлы(ИмяВременного);
		Исключение
		КонецПопытки;
		ВызватьИсключение КраткоеПредставлениеОшибки(Инфо);
	КонецПопытки;
	
	Попытка
		УдалитьФайлы(ИмяВременного);
	Исключение
	КонецПопытки;
	
	Возврат ЧислоСтрок;
	
КонецФункции

&НаСервере
Функция ИндексКолонкиПоЗаголовку(ТабДок, ОжидаемыйЗаголовок)
	
	ОжидаемыйНорм = НормализоватьТекстЗаголовкаКолонки(ОжидаемыйЗаголовок);
	Ширина = Число(ТабДок.ШиринаТаблицы);
	Для НомерКолонки = 1 По Ширина Цикл
		ТекстЯчейки = ТабДок.Область(1, НомерКолонки, 1, НомерКолонки).Текст;
		Если НормализоватьТекстЗаголовкаКолонки(ТекстЯчейки) = ОжидаемыйНорм Тогда
			Возврат НомерКолонки;
		КонецЕсли;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

&НаСервере
Функция НормализоватьТекстЗаголовкаКолонки(Текст)
	
	Результат = СокрЛП(Строка(Текст));
	Результат = СтрЗаменить(Результат, Символ(160), " ");
	Результат = СтрЗаменить(Результат, """", "");
	Результат = СтрЗаменить(Результат, "«", "");
	Результат = СтрЗаменить(Результат, "»", "");
	Возврат ВРег(СокрЛП(Результат));
	
КонецФункции

#КонецОбласти
